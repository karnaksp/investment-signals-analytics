INVESTMENT_SIGNALS_POSTGRES_HOST=host.docker.internal
INVESTMENT_SIGNALS_POSTGRES_PORT=35432
INVESTMENT_SIGNALS_POSTGRES_DB=signal_engine
INVESTMENT_SIGNALS_POSTGRES_USER=signal_engine
INVESTMENT_SIGNALS_POSTGRES_PASSWORD=signal_engine
INVESTMENT_SIGNALS_POSTGRES_SCHEMA=investment_signals_analytics

LIGHTDASH_HOST_PORT=18083
DAGSTER_HOST_PORT=13000
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001

LIGHTDASH_POSTGRES_PASSWORD=lightdash
LIGHTDASH_SECRET=change-me-for-local-stack

# Легкий локальный режим Lightdash. Образ сейчас amd64-only, поэтому на Apple Silicon используется эмуляция.
LIGHTDASH_IMAGE=lightdash/lightdash:0.3161.0
LIGHTDASH_PLATFORM=linux/amd64
LIGHTDASH_NODE_OPTIONS=--max-old-space-size=384
LIGHTDASH_MEM_LIMIT=768m
LIGHTDASH_CPUS=1.0
LIGHTDASH_DB_MEM_LIMIT=256m
LIGHTDASH_DB_CPUS=0.5
MINIO_MEM_LIMIT=256m
MINIO_CPUS=0.5

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Заполняется после создания пользователя и API key в Lightdash.
LIGHTDASH_API_KEY=
LIGHTDASH_PROJECT=
